<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- 左眼预览 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/leftScreen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightScreen"
        app:layout_constraintWidth_percent="0.45">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/taskInfoContainer" />

        <LinearLayout
            android:id="@+id/taskInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33000000"
            android:padding="8dp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/buttonContainer">
            
            <TextView
                android:id="@+id/taskInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/backButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="返回"
                android:textSize="18sp"
                android:focusable="true"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/captureButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="拍照"
                android:textSize="18sp"
                android:focusable="true"
                android:layout_marginHorizontal="4dp" />
                
            <Button
                android:id="@+id/retakeButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="重拍"
                android:textSize="18sp"
                android:focusable="true"
                android:visibility="gone"
                android:layout_marginStart="4dp" />
                
            <Button
                android:id="@+id/uploadButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="上传"
                android:textSize="18sp"
                android:focusable="true"
                android:visibility="gone"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 右眼预览 - 复制左眼界面 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rightScreen"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/leftScreen"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.45">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinderRight"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/taskInfoContainerRight" />

        <LinearLayout
            android:id="@+id/taskInfoContainerRight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#33000000"
            android:padding="8dp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/buttonContainerRight">
            
            <TextView
                android:id="@+id/taskInfoRight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/buttonContainerRight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent">

            <Button
                android:id="@+id/backButtonRight"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="返回"
                android:textSize="18sp"
                android:focusable="false"
                android:clickable="false"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/captureButtonRight"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="拍照"
                android:textSize="18sp"
                android:focusable="false"
                android:clickable="false"
                android:layout_marginHorizontal="4dp" />
                
            <Button
                android:id="@+id/retakeButtonRight"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="重拍"
                android:textSize="18sp"
                android:focusable="false"
                android:clickable="false"
                android:visibility="gone"
                android:layout_marginStart="4dp" />
                
            <Button
                android:id="@+id/uploadButtonRight"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:text="上传"
                android:textSize="18sp"
                android:focusable="false"
                android:clickable="false"
                android:visibility="gone"
                android:layout_marginStart="4dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
    
    <!-- 上传进度提示 -->
    <FrameLayout
        android:id="@+id/uploadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">
        
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="20dp"
            android:background="#333333"
            android:layout_gravity="center">
            
            <ProgressBar
                android:id="@+id/uploadProgressBar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:indeterminate="true" />
                
            <TextView
                android:id="@+id/uploadStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在上传..."
                android:textColor="@color/white"
                android:textSize="18sp"
                android:layout_marginTop="16dp" />
        </LinearLayout>
    </FrameLayout>
    
    <!-- 添加焦点控制视图 -->
    <com.rayneo.arsdk.android.demo.ui.wedget.TitleView
        android:id="@+id/photoTitleView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout> 